<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>
        <Console name="LoadTestConsole" target="SYSTEM_OUT">
            <ThresholdFilter level="DEBUG"/>
            <PatternLayout pattern="%d{dd-MM-yy HH:mm:ss,SSS}|%5.5p|%m%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <Logger name="com.lightstreamer.load_test.adapter.AdapterSimulator" level="INFO" additivity="false">
            <AppenderRef ref="LoadTestConsole"/>
        </Logger>

        <Logger name="com.lightstreamer.load_test.simulator.FeedSimulator" level="INFO" additivity="false">
            <AppenderRef ref="LoadTestConsole"/>
        </Logger>

        <!-- Logs of configuration parameters. -->
        <Logger name="com.lightstreamer.load_test.configuration" level="INFO" additivity="false">
            <AppenderRef ref="LoadTestConsole"/>
        </Logger>

        <!-- Only used when FeedSimulator is launched standalone (not as a Lightstreamer adapter).
             At TRACE level logs all the events generated by the Feed Simulator.
             If on startup this category is configured to not log TRACE events, then changing it to TRACE at runtime has no effect. -->
        <Logger name="com.lightstreamer.load_test.standalone_simulator.FeedSimulatorTest" level="INFO" additivity="false">
            <AppenderRef ref="LoadTestConsole"/>
        </Logger>

        <Root level="ERROR">
            <AppenderRef ref="LoadTestConsole"/>
        </Root>
    </Loggers>

</Configuration>